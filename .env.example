# --- Required runtime vars ---
PORT=3001
DATABASE_URL=postgresql://postgres:<password>@<host>:6543/postgres?sslmode=require
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# --- Optional Supabase metadata ---
# RiskRadar uses DATABASE_URL for DB connectivity.
# Keep these vars only if you also call Supabase HTTP APIs from custom code.
# Do not store management/personal access tokens in app runtime env unless strictly required.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...

# --- Optional email/reminder vars ---
ENABLE_REMINDER_SCHEDULER=false
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_api_key
SMTP_FROM=noreply@example.com
DEMO_DATA_MODE=true
